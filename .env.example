# 运行环境：production / development
ENV=development

# JWT 密钥 — 生产环境必须设置，开发环境不设置则每次启动随机生成
JWT_SECRET_KEY=
# JWT 旧密钥（用于密钥轮换期间验证旧 token）
JWT_SECRET_KEY_PREVIOUS=

# CORS 允许的源（逗号分隔），默认 http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# API Key 加密密钥 — 本地留空会在服务启动时自动生成并写回 .env，同时备份到 .secrets/
# 生产部署建议用 Secret/环境变量显式设置，避免容器重建后丢失。
CREDITS_ENCRYPTION_KEY=

# 服务端口（默认 8000）
PORT=8000

# 数据库路径（默认 backend/conversations.db）
DB_PATH=

# Workspace 路径（默认 backend/workspace）
WORKSPACE_BASE=

# OAuth 登录
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# 可选。请求 host 已经是公开前端地址时可以留空。
# 示例：http://localhost:5173
OAUTH_REDIRECT_BASE_URL=
